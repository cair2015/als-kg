            owl:onProperty alskb:object ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:subject ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:association_label ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:object ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:source ],
        alskb:Relationship ;
    skos:definition "Abstract base for optional evidence-bearing associations. Use when a relationship cannot be represented sufficiently by a direct object property because the edge needs provenance, evidence, confidence, or additional qualifiers. The subject/predicate/object fields allow the association to be materialized as an RDF triple or property-graph edge." ;
    skos:exactMatch biolink:Association ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:has_disease a owl:ObjectProperty ;
    rdfs:label "has_disease" ;
    rdfs:range alskb:Disease ;
    skos:definition "Referenced disease entity in an association record." ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:Disease a owl:Class ;
    rdfs:label "Disease" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:umls_cui ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:disease_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:onset_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:omim_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:icd10_code ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:omim_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:onset_type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:mondo_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:disease_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:umls_cui ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:icd10_code ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:umls_cui ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:mondo_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:orphanet_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:orphanet_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:icd10_code ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:mondo_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom alskb:DiseaseTypeEnum ;
            owl:onProperty alskb:disease_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:omim_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:orphanet_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom alskb:OnsetTypeEnum ;
            owl:onProperty alskb:onset_type ],
        alskb:DiseaseOrPhenotype ;
    skos:definition "Disease entity. Encompasses ALS (MONDO:0007743), related neurodegenerative disorders (FTD, PLS, PMA, SMA), and comorbidities. Follows MONDO disease hierarchy via is_a relationships." ;
    skos:exactMatch biolink:Disease ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:predicate a owl:DatatypeProperty ;
    rdfs:label "predicate" ;
    rdfs:range xsd:anyURI ;
    skos:definition "Direct object property represented by this association",
        "Predicate / property type IRI",
        "Relationship type IRI" ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

xsd:string a rdfs:Datatype ;
    owl:equivalentClass [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^[A-Z0-9]{6}$" ] ) ],
        [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^\\d+$" ] ) ],
        [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^Reactome:R-HSA-\\d+(\\.\\d+)?$" ] ) ],
        [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^\\d+$" ] ) ],
        [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^GO:\\d{7}$" ] ) ],
        [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^DB\\d{5}$" ] ) ],
        [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^HP:\\d{7}$" ] ) ],
        [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^MONDO:\\d{7}$" ] ) ],
        [ a rdfs:Datatype ;
            owl:onDatatype xsd:string ;
            owl:withRestrictions ( [ xsd:pattern "^UBERON:\\d+$" ] ) ] .


