    rdfs:label "protein_coding" ;
    rdfs:subClassOf alskb:GeneTypeEnum .

<https://cair2015.github.io/als-kg/elements/GeneTypeEnum#pseudogene> a owl:Class ;
    rdfs:label "pseudogene" ;
    rdfs:subClassOf alskb:GeneTypeEnum .

