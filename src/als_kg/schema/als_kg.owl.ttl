    skos:definition "Optional association for Drug -> MolecularEntity when action type, binding affinity, target class, or mechanism evidence is needed. Materializes to drug_targets_molecular_entity." ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:ExposureDiseaseAssociation a owl:Class ;
    rdfs:label "ExposureDiseaseAssociation" ;
    rdfs:subClassOf [ a owl:Restriction ;
