@prefix alskb: <https://cair2015.github.io/als-kg/elements/> .
@prefix biolink: <https://w3id.org/biolink/vocab/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix pav: <http://purl.org/pav/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://cair2015.github.io/als-kg.owl.ttl> a owl:Ontology ;
    rdfs:label "als_kg" ;
    dcterms:license "MIT" ;
    dcterms:title "ALS Knowledge Graph Ontology Model" ;
    pav:version "2.1.2" ;
    skos:definition "Comprehensive ontology model for the ALS Knowledge Graph (ALS-KG). Uses a local default namespace for ALS-specific classes and slots, explicit Biolink/ontology URIs only for externally defined concepts and predicates, direct object properties for canonical KG edges, and optional evidence-bearing association classes for provenance-rich statements." ;
    skos:note "Reactome pathways are modeled as Pathway entities using Reactome stable identifiers; KEGG pathway prefixes and KEGG-specific mappings are intentionally omitted.",
        "URI policy: ALS-KG-specific classes and slots use the schema default_prefix (alskb) and do not need explicit class_uri/slot_uri declarations. Use class_uri/slot_uri only when a term is intended to be equivalent to an external model term; use exact_mappings or close_mappings when alignment is useful but not identical." .

alskb:DiseaseDiseaseAssociation a owl:Class ;
    rdfs:label "DiseaseDiseaseAssociation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:shared_mechanism ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:predicate ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:relation_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom alskb:Disease ;
            owl:onProperty alskb:disease_1 ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:float ;
            owl:onProperty alskb:similarity_score ],
        [ a owl:Restriction ;
            owl:allValuesFrom alskb:Disease ;
            owl:onProperty alskb:disease_2 ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:similarity_score ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:predicate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:shared_mechanism ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:relation_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:similarity_score ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:disease_2 ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:disease_1 ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:predicate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:relation_type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:disease_1 ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:disease_2 ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:shared_mechanism ],
        alskb:Association ;
    skos:definition "Optional association for Disease -> Disease when disease-disease edges need relation type, similarity score, shared mechanism, or comorbidity statistics. Materializes to disease_related_to_disease." ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:DiseasePhenotypeAssociation a owl:Class ;
    rdfs:label "DiseasePhenotypeAssociation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:predicate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:has_disease ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:cohort ],
        [ a owl:Restriction ;
            owl:allValuesFrom alskb:OnsetTypeEnum ;
            owl:onProperty alskb:onset_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:cohort ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:severity ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:has_phenotype ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:frequency ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:cohort ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:has_disease ],
        [ a owl:Restriction ;
            owl:allValuesFrom alskb:Disease ;
            owl:onProperty alskb:has_disease ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:onset_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:has_phenotype ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:predicate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:frequency ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:predicate ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:frequency ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:severity ],
        [ a owl:Restriction ;
            owl:allValuesFrom alskb:Phenotype ;
            owl:onProperty alskb:has_phenotype ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:onset_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:severity ],
        alskb:Association ;
    skos:definition "Optional association for Disease -> Phenotype when the clinical feature requires edge metadata such as frequency, onset, severity, source cohort, or evidence. Materializes to disease_manifests_as_phenotype." ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:DiseaseSubtype a owl:Class ;
    rdfs:label "DiseaseSubtype" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:cluster_method ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:clinical_correlate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:clinical_correlate ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:cohort ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:median_survival_months ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:clinical_correlate ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:signature_genes ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:cluster_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:cluster_method ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:cluster_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:signature_genes ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:subtype_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:source_publication ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:source_publication ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:cohort ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:subtype_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:cohort ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:float ;
            owl:onProperty alskb:median_survival_months ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:n_patients ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:subtype_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:cluster_method ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:median_survival_months ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:source_publication ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:n_patients ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty alskb:n_patients ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:integer ;
            owl:onProperty alskb:cluster_id ],
        alskb:Disease ;
    skos:definition "Molecularly-defined disease subtype derived from clustering analysis (transcriptomics, proteomics, multi-omics). Represents cohort stratification. Links to Disease via is_a relationship; carries distinct clinical correlates." ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:DrugDiseaseTherapeuticAssociation a owl:Class ;
    rdfs:label "DrugDiseaseTherapeuticAssociation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
