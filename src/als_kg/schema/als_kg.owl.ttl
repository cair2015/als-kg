            owl:onProperty alskb:approval_status ],
        [ a owl:Restriction ;
            owl:allValuesFrom alskb:Drug ;
            owl:onProperty alskb:has_drug ],
        alskb:Association ;
    skos:definition "Optional association for Drug -> Disease when therapeutic indication, approval status, clinical-trial evidence, or outcome metadata are needed. Materializes to drug_treats_or_modulates_disease." ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:DrugTargetAssociation a owl:Class ;
    rdfs:label "DrugTargetAssociation" ;
