<https://cair2015.github.io/als-kg/elements/OnsetTypeEnum#limb> a owl:Class ;
    rdfs:label "limb" ;
    rdfs:subClassOf alskb:OnsetTypeEnum ;
    skos:definition "Arm or leg muscles affected first" .

<https://cair2015.github.io/als-kg/elements/OnsetTypeEnum#respiratory> a owl:Class ;
    rdfs:label "respiratory" ;
    rdfs:subClassOf alskb:OnsetTypeEnum ;
    skos:definition "Breathing muscles affected first" .

<https://cair2015.github.io/als-kg/elements/OnsetTypeEnum#unknown> a owl:Class ;
    rdfs:label "unknown" ;
    rdfs:subClassOf alskb:OnsetTypeEnum ;
    skos:definition "Onset location unknown" .

<https://cair2015.github.io/als-kg/elements/RelationshipTypeEnum#affects> a owl:Class ;
    rdfs:label "affects" ;
    rdfs:subClassOf alskb:RelationshipTypeEnum ;
