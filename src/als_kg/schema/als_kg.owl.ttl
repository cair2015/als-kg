            owl:onProperty alskb:predicate ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:predicate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:approval_status ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:relation_type ],
