<https://cair2015.github.io/als-kg/elements/RelationshipTypeEnum#has_participant> a owl:Class ;
    rdfs:label "has_participant" ;
    rdfs:subClassOf alskb:RelationshipTypeEnum ;
    skos:definition "Process has participant" .

<https://cair2015.github.io/als-kg/elements/RelationshipTypeEnum#is_a> a owl:Class ;
    rdfs:label "is_a" ;
    rdfs:subClassOf alskb:RelationshipTypeEnum ;
    skos:definition "Subclass relationship (taxonomic)" .

<https://cair2015.github.io/als-kg/elements/RelationshipTypeEnum#negatively_regulates> a owl:Class ;
    rdfs:label "negatively_regulates" ;
    rdfs:subClassOf alskb:RelationshipTypeEnum ;
    skos:definition "Downregulation/inhibition" .

<https://cair2015.github.io/als-kg/elements/RelationshipTypeEnum#part_of> a owl:Class ;
    rdfs:label "part_of" ;
    rdfs:subClassOf alskb:RelationshipTypeEnum ;
    skos:definition "Mereological (compositional) relationship" .

<https://cair2015.github.io/als-kg/elements/RelationshipTypeEnum#participates_in> a owl:Class ;
    rdfs:label "participates_in" ;
    rdfs:subClassOf alskb:RelationshipTypeEnum ;
    skos:definition "Agent participates in process" .

<https://cair2015.github.io/als-kg/elements/RelationshipTypeEnum#positively_regulates> a owl:Class ;
    rdfs:label "positively_regulates" ;
    rdfs:subClassOf alskb:RelationshipTypeEnum ;
    skos:definition "Upregulation/activation" .

<https://cair2015.github.io/als-kg/elements/RelationshipTypeEnum#proper_part_of> a owl:Class ;
    rdfs:label "proper_part_of" ;
    rdfs:subClassOf alskb:RelationshipTypeEnum ;
    skos:definition "Strict part-of (excludes identity)" .

<https://cair2015.github.io/als-kg/elements/RelationshipTypeEnum#regulates> a owl:Class ;
    rdfs:label "regulates" ;
    rdfs:subClassOf alskb:RelationshipTypeEnum ;
    skos:definition "Regulatory relationship (direction unspecified)" .

alskb:TranscriptionFactor a owl:Class ;
    rdfs:label "TranscriptionFactor" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:tf_family ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:dorothea_confidence ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:tf_family ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:dorothea_confidence ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:tf_family ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:dorothea_confidence ],
        alskb:Gene ;
    skos:definition "Gene encoding a transcription factor (TF). Subclass of Gene, carries both :Gene and :TranscriptionFactor labels. Source: DoRothEA + ENCODE TF annotations." ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

<https://cair2015.github.io/als-kg/elements/VariantTypeEnum#CNV> a owl:Class ;
    rdfs:label "CNV" ;
    rdfs:subClassOf alskb:VariantTypeEnum ;
    skos:definition "Copy number variation" .

<https://cair2015.github.io/als-kg/elements/VariantTypeEnum#SNV> a owl:Class ;
    rdfs:label "SNV" ;
    rdfs:subClassOf alskb:VariantTypeEnum ;
    skos:definition "Single nucleotide variant" .

<https://cair2015.github.io/als-kg/elements/VariantTypeEnum#indel> a owl:Class ;
    rdfs:label "indel" ;
    rdfs:subClassOf alskb:VariantTypeEnum ;
    skos:definition "Insertion or deletion" .

<https://cair2015.github.io/als-kg/elements/VariantTypeEnum#repeat_expansion> a owl:Class ;
    rdfs:label "repeat_expansion" ;
    rdfs:subClassOf alskb:VariantTypeEnum ;
    skos:definition "Trinucleotide repeat expansion" .

<https://cair2015.github.io/als-kg/elements/VariantTypeEnum#structural> a owl:Class ;
    rdfs:label "structural" ;
    rdfs:subClassOf alskb:VariantTypeEnum ;
    skos:definition "Structural variant (inversion, translocation)" .

alskb:parent_pathway a owl:DatatypeProperty ;
    rdfs:label "parent_pathway" ;
    skos:definition "Parent Reactome pathway CURIE when available" ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:signature_genes a owl:DatatypeProperty ;
    rdfs:label "signature_genes" ;
    skos:definition "Top discriminative genes for subtype" ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:subcellular_location a owl:DatatypeProperty ;
    rdfs:label "subcellular_location" ;
    skos:definition "Cellular compartment(s) where protein is localized (e.g. mitochondrion, nucleus, axon)" ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:synonym a owl:DatatypeProperty ;
    rdfs:label "synonym" ;
    rdfs:range xsd:string ;
    skos:definition "Alternative names",
        "Alternative names or labels" ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:xref a owl:DatatypeProperty ;
    rdfs:label "xref" ;
    rdfs:range xsd:string ;
    skos:definition "Cross-reference to equivalent entity in another ontology. Format: ONTOLOGY_PREFIX:identifier (e.g. OMIM:104300, Reactome:R-HSA-5673001, GO:0006810)",
        "Cross-references to external ontologies" ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:Pathway a owl:Class ;
    rdfs:label "Pathway" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:reactome_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:parent_pathway ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:reactome_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:pathway_definition ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:pathway_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:species ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:pathway_definition ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:species ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:pathway_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:species ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:reactome_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:pathway_definition ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:pathway_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:parent_pathway ],
        alskb:BiologicalConcept ;
    skos:definition "Reactome pathway entity representing a curated biological pathway or reaction-level pathway context relevant to ALS mechanisms, including neuroinflammation, RNA metabolism, protein homeostasis, mitochondrial dysfunction, and axonal transport." ;
    skos:exactMatch biolink:Pathway ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:Phenotype a owl:Class ;
    rdfs:label "Phenotype" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:frequency ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:severity ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:hpo_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:hpo_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:severity ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:frequency ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:frequency ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:severity ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:hpo_id ],
        alskb:DiseaseOrPhenotype ;
    skos:definition "Phenotypic feature (HPO term). Represents observable/measurable characteristics associated with diseases. Distinct from drug side effects which are modeled via DrugCausesPhenotype relationships." ;
    skos:exactMatch biolink:PhenotypicFeature ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:action_type a owl:DatatypeProperty ;
    rdfs:label "action_type" ;
    skos:definition "inhibitor, activator, binder, antagonist, agonist, modulator, ASO_knockdown, or unknown" ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:adjusted_p_value a owl:DatatypeProperty ;
    rdfs:label "adjusted_p_value" ;
