        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:last_updated ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:ingest_date ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:subject ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:source_version ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:ingest_date ],
        [ a owl:Restriction ;
