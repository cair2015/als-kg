    rdfs:domain alskb:Drug ;
    rdfs:range alskb:Disease ;
    skos:closeMatch biolink:treats ;
    skos:definition "Drug treats, modifies, palliates, or is being investigated for a disease." ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:exposure_associated_with_disease a owl:ObjectProperty ;
    rdfs:label "exposure_associated_with_disease" ;
    rdfs:domain alskb:ExposureOrStressor ;
    rdfs:range alskb:Disease ;
    skos:closeMatch biolink:associated_with ;
