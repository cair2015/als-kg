alskb:Anatomy a owl:Class ;
    rdfs:label "Anatomy" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:bto_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:anatomical_system ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:uberon_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:anatomical_system ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:anatomical_system ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:mesh_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:mesh_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:uberon_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:mesh_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:uberon_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:bto_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:bto_id ],
        alskb:OntologyClass ;
    skos:definition "Anatomical structure (UBERON ontology). ALS-specific relevance: motor cortex, spinal cord, anterior horn cells, neuromuscular junction. Linked to gene expression and disease manifestation." ;
    skos:exactMatch biolink:AnatomicalEntity ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:BiologicalConcept a owl:Class ;
    rdfs:label "BiologicalConcept" ;
    rdfs:subClassOf alskb:OntologyClass ;
    skos:definition "Abstract base for functional/biological concepts from GO and related ontologies. Represents processes, functions, and compartments involved in ALS pathology." ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:DiseaseTypeEnum a owl:Class ;
    rdfs:label "DiseaseTypeEnum" ;
    owl:unionOf ( <https://cair2015.github.io/als-kg/elements/DiseaseTypeEnum#sporadic> <https://cair2015.github.io/als-kg/elements/DiseaseTypeEnum#familial> <https://cair2015.github.io/als-kg/elements/DiseaseTypeEnum#syndromic> ) ;
    skos:inScheme <https://cair2015.github.io/als-kg> ;
    linkml:permissible_values <https://cair2015.github.io/als-kg/elements/DiseaseTypeEnum#familial>,
        <https://cair2015.github.io/als-kg/elements/DiseaseTypeEnum#sporadic>,
        <https://cair2015.github.io/als-kg/elements/DiseaseTypeEnum#syndromic> .

alskb:Drug a owl:Class ;
    rdfs:label "Drug" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:inchi_key ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty alskb:als_approved ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:mechanism ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:chembl_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:trial_status ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:trial_status ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:drug_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:als_approved ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:drug_name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:smiles ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:inchi_key ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:chembl_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:indication ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:inchi_key ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:drugbank_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:smiles ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:indication ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:indication ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:drug_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:drugbank_id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:drugbank_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:drug_name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:drug_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:trial_status ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
