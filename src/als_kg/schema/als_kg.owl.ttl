            owl:onProperty alskb:last_updated ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:synonym ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:comment ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:source ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:synonym ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:is_obsolete ] ;
    skos:definition "Root class for all named entities in the ALS-KG ontology. Provides core ontology metadata (id, label, definition, synonyms, xrefs)." ;
    skos:exactMatch biolink:NamedThing ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:Relationship a owl:Class ;
    rdfs:label "Relationship" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:source ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:confidence ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:object ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:object ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:confidence ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:source ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:predicate ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:ingest_date ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:evidence_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:ingest_date ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:evidence_source ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:evidence_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:subject ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:object ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:subject ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:evidence_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:evidence_source ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:predicate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:confidence ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:predicate ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:evidence_source ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:subject ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:source ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:ingest_date ] ;
    skos:definition "Abstract base for reified relationships (edges with explicit properties). Follows RDF triple pattern: subject, predicate, object. Can carry additional metadata (confidence, evidence, provenance)." ;
    skos:exactMatch rdf:Statement ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:ChemicalEntity a owl:Class ;
    rdfs:label "ChemicalEntity" ;
    rdfs:subClassOf alskb:OntologyClass ;
    skos:definition "Abstract base for chemical and pharmacological entities (drugs, exposures, metabolites)." ;
    skos:exactMatch biolink:ChemicalEntity ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:DiseaseOrPhenotype a owl:Class ;
    rdfs:label "DiseaseOrPhenotype" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:mondo_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:hpo_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:mondo_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:hpo_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:hpo_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:mondo_id ],
        alskb:OntologyClass ;
    skos:definition "Abstract parent class for all disease/phenotype entities. Following MONDO and HPO ontology patterns." ;
    skos:exactMatch biolink:DiseaseOrPhenotypicFeature ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

<https://cair2015.github.io/als-kg/elements/DiseaseTypeEnum#familial> a owl:Class ;
    rdfs:label "familial" ;
    rdfs:subClassOf alskb:DiseaseTypeEnum ;
