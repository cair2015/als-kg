alskb:variant_associated_with_disease a owl:ObjectProperty ;
    rdfs:label "variant_associated_with_disease" ;
    rdfs:domain alskb:Variant ;
    rdfs:range alskb:Disease ;
    skos:definition "Sequence variant has causal, risk, modifier, protective, or correlative association with disease." ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:BiologicalProcess a owl:Class ;
    rdfs:label "BiologicalProcess" ;
