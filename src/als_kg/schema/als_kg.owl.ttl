        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:relation_type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:has_drug ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:relation_type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:has_disease ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:outcome_measure ],
        [ a owl:Restriction ;
