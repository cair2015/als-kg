            owl:onProperty alskb:drug_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:als_approved ],
        alskb:ChemicalEntity ;
    skos:definition "Pharmaceutical compound (DrugBank model). ALS-approved drugs: Riluzole, Edaravone, Tofersen, AMX0035. Includes mechanism, targets, side effects." ;
    skos:exactMatch biolink:Drug ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:GeneTypeEnum a owl:Class ;
