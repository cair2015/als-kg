alskb:disease_affects_anatomy a owl:ObjectProperty ;
    rdfs:label "disease_affects_anatomy" ;
    rdfs:domain alskb:Disease ;
    rdfs:range alskb:Anatomy ;
    skos:closeMatch biolink:affects ;
    skos:definition "Disease affects, involves, or primarily manifests in an anatomical structure." ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:disease_manifests_as_phenotype a owl:ObjectProperty ;
    rdfs:label "disease_manifests_as_phenotype" ;
    rdfs:domain alskb:Disease ;
    rdfs:range alskb:Phenotype ;
    skos:definition "Disease has or presents with a phenotype or clinical feature." ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:disease_related_to_disease a owl:ObjectProperty ;
    rdfs:label "disease_related_to_disease" ;
    rdfs:domain alskb:Disease ;
    rdfs:range alskb:Disease ;
    skos:definition "Disease is related to another disease by comorbidity, shared etiology, similar mechanism, or phenotypic similarity." ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:drug_targets_molecular_entity a owl:ObjectProperty ;
    rdfs:label "drug_targets_molecular_entity" ;
    rdfs:domain alskb:Drug ;
    rdfs:range alskb:MolecularEntity ;
    skos:definition "Drug, biologic, ASO, or other therapeutic agent targets a gene or protein." ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:drug_treats_or_modulates_disease a owl:ObjectProperty ;
