alskb:approval_status a owl:DatatypeProperty ;
    rdfs:label "approval_status" ;
    skos:definition "approved, investigational, withdrawn, off_label, failed_trial, or unknown" ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:association_id a owl:DatatypeProperty ;
    rdfs:label "association_id" ;
    skos:definition "Stable identifier for the association record" ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:association_label a owl:DatatypeProperty ;
    rdfs:label "association_label" ;
    skos:definition "Human-readable summary of the association" ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:association_score a owl:DatatypeProperty ;
    rdfs:label "association_score" ;
    skos:definition "Source-specific gene-disease association score" ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:binding_affinity_nm a owl:DatatypeProperty ;
    rdfs:label "binding_affinity_nm" ;
