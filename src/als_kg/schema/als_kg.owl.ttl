        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:exposure ],
        [ a owl:Restriction ;
            owl:allValuesFrom alskb:Disease ;
            owl:onProperty alskb:has_disease ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:predicate ],
        alskb:Association ;
    skos:definition "Optional association for ExposureOrStressor -> Disease when epidemiology, mechanism, dose, duration, population, or study design metadata are needed. Materializes to exposure_associated_with_disease." ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:GeneDiseaseAssociation a owl:Class ;
