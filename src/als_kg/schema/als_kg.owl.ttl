    skos:exactMatch owl:Class ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

alskb:Variant a owl:Class ;
    rdfs:label "Variant" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:clinvar_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:hgvs_c ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:clinvar_id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:als_class ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:hgvs_p ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:als_class ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:maf ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:clinical_significance ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:variant_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:rsid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:clinical_significance ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:maf ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:clinvar_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:hgvs_p ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:variant_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:hgvs_p ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:hgvs_c ],
        [ a owl:Restriction ;
            owl:allValuesFrom [ a rdfs:Datatype ;
                    owl:intersectionOf ( xsd:float [ a rdfs:Datatype ;
                                owl:onDatatype xsd:float ;
                                owl:withRestrictions ( [ xsd:minInclusive 0e+00 ] ) ] [ a rdfs:Datatype ;
                                owl:onDatatype xsd:float ;
                                owl:withRestrictions ( [ xsd:maxInclusive 1e+00 ] ) ] ) ] ;
            owl:onProperty alskb:maf ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:rsid ],
        [ a owl:Restriction ;
            owl:allValuesFrom alskb:VariantTypeEnum ;
            owl:onProperty alskb:variant_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:als_class ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:hgvs_c ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:rsid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:clinical_significance ],
        alskb:MolecularEntity ;
    skos:definition "Genetic sequence variant (ClinVar model). Includes SNVs, indels, repeat expansions (C9orf72), and structural variants. Links to genes, proteins, and disease associations." ;
    skos:exactMatch biolink:SequenceVariant ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

