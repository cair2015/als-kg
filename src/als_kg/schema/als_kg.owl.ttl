alskb:assay a owl:DatatypeProperty .

alskb:clinical_significance a owl:DatatypeProperty .

alskb:cohort a owl:DatatypeProperty .

alskb:confidence a owl:DatatypeProperty ;
    rdfs:label "confidence" ;
    rdfs:range [ a rdfs:Datatype ;
            owl:intersectionOf ( xsd:float [ a rdfs:Datatype ;
                        owl:onDatatype xsd:float ;
                        owl:withRestrictions ( [ xsd:minInclusive 0e+00 ] ) ] [ a rdfs:Datatype ;
                        owl:onDatatype xsd:float ;
                        owl:withRestrictions ( [ xsd:maxInclusive 1e+00 ] ) ] ) ] ;
    skos:definition "Confidence or quality score (0.0-1.0)" ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

