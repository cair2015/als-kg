            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:ensembl_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:genomic_pos_start ],
        [ a owl:Restriction ;
