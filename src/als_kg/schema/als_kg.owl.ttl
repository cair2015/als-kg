            owl:onProperty alskb:subject ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:ingest_date ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:evidence_source ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
