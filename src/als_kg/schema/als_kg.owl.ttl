<https://cair2015.github.io/als-kg/elements/EvidenceTypeEnum#text_mined> a owl:Class ;
    rdfs:label "text_mined" ;
    rdfs:subClassOf alskb:EvidenceTypeEnum ;
    skos:definition "Extracted via natural language processing" .

alskb:ExposureOrStressor a owl:Class ;
    rdfs:label "ExposureOrStressor" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:als_relevance ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:ctd_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:cas_number ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:exposure_name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:exposure_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:exposure_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:mesh_id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty alskb:ctd_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:ctd_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:mesh_id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:exposure_name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty alskb:als_relevance ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:exposure_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:boolean ;
            owl:onProperty alskb:als_relevance ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:cas_number ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty alskb:mesh_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:cas_number ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty alskb:exposure_type ],
        alskb:ChemicalEntity ;
    skos:definition "Environmental exposure or chemical stressor from CTD ontology. ALS-relevant: BMAA, organophosphate pesticides, heavy metals, solvents." ;
    skos:exactMatch biolink:ChemicalSubstance ;
    skos:inScheme <https://cair2015.github.io/als-kg> .

<https://cair2015.github.io/als-kg/elements/GeneTypeEnum#lncRNA> a owl:Class ;
    rdfs:label "lncRNA" ;
    rdfs:subClassOf alskb:GeneTypeEnum .

<https://cair2015.github.io/als-kg/elements/GeneTypeEnum#miRNA> a owl:Class ;
    rdfs:label "miRNA" ;
    rdfs:subClassOf alskb:GeneTypeEnum .

