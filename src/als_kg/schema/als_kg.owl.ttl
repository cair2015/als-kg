<https://cair2015.github.io/als-kg/elements/EvidenceTypeEnum#curated> a owl:Class ;
    rdfs:label "curated" ;
    rdfs:subClassOf alskb:EvidenceTypeEnum ;
    skos:definition "Manually curated from literature" .

<https://cair2015.github.io/als-kg/elements/EvidenceTypeEnum#experimental> a owl:Class ;
    rdfs:label "experimental" ;
    rdfs:subClassOf alskb:EvidenceTypeEnum ;
    skos:definition "Derived from wet-lab experiments" .

<https://cair2015.github.io/als-kg/elements/EvidenceTypeEnum#inferred> a owl:Class ;
